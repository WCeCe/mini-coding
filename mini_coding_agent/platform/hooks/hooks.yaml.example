# 复制到 <workspace>/.mini-coding-agent/hooks.yaml 后生效。
# 缺省：未创建该文件时使用代码内默认值（各内置 Hook 均为 true）。

builtin_hooks:
  # ToolTraceHook → session["tool_trace"]（步序、耗时、成败）
  session_trace: true

  # TraceDisplayHook → stderr 每步 tool 一行摘要
  trace_display: true

  # ShellAuditHook → run_shell 危险模式告警（不阻断）
  shell_audit: true

  # AskTimingHook → .mini-coding-agent/logs/<session_id>.jsonl（ask 级 llm/tool 耗时）
  ask_timing: true

# shell 审计自定义模式（可选）
# shell_audit:
#   warn_patterns:
#     - "rm -rf"
#     - "curl.*\\|.*sh"
